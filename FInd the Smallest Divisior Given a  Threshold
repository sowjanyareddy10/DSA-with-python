from math import ceil  
class Solution:
    def smallestDivisor(self, nums: List[int], threshold: int) -> int:
        n=len(nums)
        low=1
        high=max(nums)
        while(low<=high):
            mid=(low+high)//2
            Sum=0
            for num in nums:
                Sum+=ceil(num/mid)
            if(Sum<=threshold):
                high=mid-1
            else:
                low=mid+1
        return low
        
